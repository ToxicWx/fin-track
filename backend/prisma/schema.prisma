generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AssetType {
  CRYPTO
  BANK_ACCOUNT
  CASH
  VEHICLE
  REAL_ESTATE
  PRECIOUS_METAL
  SECURITIES
  BUSINESS
  COLLECTIBLE
  OTHER
}

enum CredentialProvider {
  BINANCE
  MONOBANK
  BLOCKSCAN
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum RateSource {
  NBU
  BINANCE
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")

  assets Asset[]

  @@map("users")
}

model Asset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      AssetType
  name      String
  balance   Decimal   @db.Decimal(18, 4)
  currency  String    @db.VarChar(16)
  isAuto    Boolean   @default(false) @map("is_auto")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  credential    AssetCredential?
  transactions  Transaction[]

  @@index([userId])
  @@map("assets")
}

model AssetCredential {
  id           String             @id @default(uuid()) @db.Uuid
  assetId      String             @unique @map("asset_id") @db.Uuid
  encryptedKey String             @map("encrypted_key")
  keyIv        String             @map("key_iv")
  encryptedSecret String?         @map("encrypted_secret")
  secretIv        String?         @map("secret_iv")
  externalIdentifier String?      @map("external_identifier")
  tokenDecimals      Int?         @map("token_decimals")
  provider     CredentialProvider

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("asset_credentials")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  assetId     String          @map("asset_id") @db.Uuid
  externalId  String?         @unique @map("external_id")
  amount      Decimal         @db.Decimal(18, 4)
  type        TransactionType
  category    String
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("transactions")
}

model CurrencyRate {
  code      String     @id @db.VarChar(16)
  rateToUah Decimal    @map("rate_to_uah") @db.Decimal(18, 6)
  source    RateSource
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("currency_rates")
}
